# Copy to .env and fill in values. Never commit .env.

NODE_ENV=development
PORT=3000

# --- PostgreSQL (your machine) ---
# No password: omit :password@ — use your OS username if Postgres uses peer/trust auth.
USE_POSTGRES=true
DATABASE_URL=postgresql://haiderimran@localhost:5432/jira_confluencer
# First-time dev: let TypeORM create tables from entities. Turn off after schema is stable.
TYPEORM_SYNC=true

# After .env is set: npm run db:seed   (sample DEMO-1 + Confluence row)
# App: npm run dev

# --- In-memory only (no Postgres) ---
# USE_POSTGRES=false
# (leave DATABASE_URL unset or empty)

# Shared secret Jira will send (query param or header — you choose in implementation)
JIRA_WEBHOOK_SECRET=

# Atlassian Cloud site: base URL only (not /jira/software/...).
# Example: https://imranhaider00047.atlassian.net
ATLASSIAN_SITE_URL=

# Basic auth style for scripts: email + API token
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=

# Optional — Jira scripts
# JIRA_PROJECT_KEY=KAN
# JIRA_ISSUE_TYPE=Task
# JIRA_HELLO_ISSUE_KEY=KAN-1   # hello-world issue; sync:hello-doc-done moves it to Done
# CONFLUENCE_SPACE_KEY=        # optional; if "Software Development" is not found by name
