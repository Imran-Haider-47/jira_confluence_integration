{
  "name": "jira-confluencer-synchronizer-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Jira webhooks → Confluence sync service (backend only)",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "jira:create-issue": "tsx scripts/create-sample-issue.ts",
    "db:seed": "tsx scripts/seed-postgres.ts",
    "jira:board-update": "tsx scripts/jira-board-update.ts",
    "sync:hello-doc-done": "tsx scripts/hello-world-confluence-and-jira-done.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "pg": "^8.13.1",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
